# `.env` や process env に値が無い項目は、ローカル実行時に `azd env get-values`
# からも補完されます。複数環境を使う場合は `azd env select <name>` を先に実行してください。

# --- 必須（Azure 接続する場合） ---
# Microsoft Foundry プロジェクトエンドポイント
AZURE_AI_PROJECT_ENDPOINT=https://your-foundry.services.ai.azure.com/api/projects/your-project
# 推論モデル名（デフォルト: gpt-5-4-mini）
MODEL_NAME=gpt-5-4-mini

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx

# --- 環境設定 ---
# development / production / staging（本番では必須設定の検証が有効になる）
ENVIRONMENT=development
# 静的ファイル配信（本番のみ true。Container Apps で React を FastAPI から配信する場合）
SERVE_STATIC=false

# --- CORS（カンマ区切り、デフォルト: http://localhost:5173） ---
ALLOWED_ORIGINS=http://localhost:5173

# --- Cosmos DB（未設定時はインメモリフォールバック） ---
COSMOS_DB_ENDPOINT=https://your-cosmos.documents.azure.com:443/

# --- Fabric Data（Data Agent 優先、未設定時は SQL → CSV フォールバック） ---
FABRIC_DATA_AGENT_URL=https://api.fabric.microsoft.com/v1/workspaces/<workspace-id>/dataagents/<data-agent-id>/aiassistant/openai
FABRIC_SQL_ENDPOINT=your-fabric-sql-endpoint.datawarehouse.fabric.microsoft.com

# --- Foundry Evaluation（未設定時は MODEL_NAME を使って評価） ---
EVAL_MODEL_DEPLOYMENT=gpt-4-1-mini

# --- Improvement MCP（APIM で公開した MCP endpoint。未設定時は既存の改善ロジックへフォールバック） ---
# 例: https://your-apim.azure-api.net/improvement-mcp/runtime/webhooks/mcp
IMPROVEMENT_MCP_ENDPOINT=
# APIM subscription key などを使う場合だけ設定
IMPROVEMENT_MCP_API_KEY=
# direct function key を使う場合は x-functions-key などへ変更
IMPROVEMENT_MCP_API_KEY_HEADER=Ocp-Apim-Subscription-Key

# --- Content Understanding（PDF 解析、未設定時はスキップ） ---
CONTENT_UNDERSTANDING_ENDPOINT=https://your-foundry.cognitiveservices.azure.com/

# --- Logic Apps callback（承認継続後の通知・保存、未設定時はスキップ） ---
LOGIC_APP_CALLBACK_URL=https://your-logic-app-trigger-url

# --- Manager approval trigger（Teams 対応 workflow を別途用意して設定） ---
MANAGER_APPROVAL_TRIGGER_URL=https://your-manager-approval-workflow-trigger-url

# --- Teams Webhook URL（MCP notify_teams 用、未設定時はログのみ） ---
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/xxx

# --- SharePoint サイト URL（MCP save_to_sharepoint 用、未設定時はログのみ） ---
SHAREPOINT_SITE_URL=https://your-org.sharepoint.com/sites/marketing

# --- Foundry IQ Knowledge Base ---
# project_endpoint（AZURE_AI_PROJECT_ENDPOINT）を設定すると自動的に有効化。
# Foundry IQ のナレッジインデックスが Azure AI Search 経由で検索されます。
# 未設定時はハードコードの NG 表現リスト・旅行業法チェックリストをフォールバックとして使用。

# --- Web Search (Bing Grounding) ---
# Foundry プロジェクトに Bing Grounding 接続が構成されていれば自動的に有効化。
# Agent2（施策生成）の市場トレンド検索、Agent3（規制チェック）の安全情報検索で使用。
# 未設定時は静的なフォールバックデータを返します。

# --- Marketing plan runtime switch ---
# foundry_preprovisioned: 事前作成済み Foundry Agent を既定で使用
# legacy: 現行のローカル Agent Framework 実装（緊急切り分け用）
MARKETING_PLAN_RUNTIME=foundry_preprovisioned
# foundry_tool: 既定。Foundry Agent をベースに per-user delegated Work IQ connector を重ねる
# graph_prefetch: rollback。Graph Copilot Chat API で brief を先読みして prompt に注入
WORKIQ_RUNTIME=foundry_tool
# Foundry Prompt Agent の名前。runtime が foundry_preprovisioned のときに使用。
MARKETING_PLAN_PROMPT_AGENT_NAME=travel-marketing-plan

# --- Code Interpreter（データ可視化、デフォルト: 有効） ---
# Agent1 が売上データのグラフ可視化に使用する。初回実行時に 404 が発生すると
# 自動的に無効化してテキスト分析のみで動作する。
# 明示的に無効化したい場合は false を設定。
# ENABLE_CODE_INTERPRETER=true

# --- Azure AI Search bootstrap（scripts/setup_knowledge_base.py 用、任意） ---
# 実行時検索は SEARCH_ENDPOINT / SEARCH_API_KEY を優先し、未設定時のみ
# Foundry project の Azure AI Search 既定接続へフォールバックします。
# SEARCH_ENDPOINT=https://your-search.search.windows.net
# SEARCH_API_KEY=your-search-admin-key

# --- MAI image route（別の MAI 対応 AI Services account、未設定時はフォールバック） ---
# アプリ既定の画像経路は gpt-image-2 です。GPT 系画像モデルは project endpoint 側の deployment 名を使います。
# deployment 名が既定と異なる場合だけ上書きしてください。
# GPT_IMAGE_15_DEPLOYMENT_NAME=gpt-image-1.5
# GPT_IMAGE_2_DEPLOYMENT_NAME=gpt-image-2
#
# 現在の rebuilt tenant では East US の別 account を使い、
# `MAI-Image-2` deployment 名を `MAI-Image-2e` の alias として運用している。
IMAGE_PROJECT_ENDPOINT_MAI=https://your-mai-resource.services.ai.azure.com

# --- Photo Avatar + Voice Live（販促動画生成） ---
# Azure AI Speech Service の Photo Avatar API を使用してアバター動画を生成する。
# 未設定時は動画生成をスキップします。
SPEECH_SERVICE_ENDPOINT=https://your-region.api.cognitive.microsoft.com
SPEECH_SERVICE_REGION=eastus2
VIDEO_GEN_VOICE=ja-JP-Nanami:DragonHDLatestNeural
VIDEO_GEN_AVATAR_STYLE=casual-sitting
# VIDEO_GEN_AVATAR_CHARACTER=lisa
# VIDEO_GEN_BACKGROUND_COLOR=#FFFFFFFF
# VIDEO_GEN_BITRATE_KBPS=4000

# Voice Live（音声入力）
VOICE_AGENT_NAME=travel-voice-orchestrator
VOICE_SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Work IQ / Microsoft Graph Copilot Chat API
# 既定の foundry_tool 経路では browser が https://ai.azure.com/user_impersonation を取得し、
# backend がその token を Foundry Responses へ渡して Work IQ MCP connection を per-user で実行する。
# graph_prefetch rollback を使う場合だけ Microsoft Graph delegated permissions / admin consent が必要。
WORK_IQ_TIMEOUT_SECONDS=120

# --- API Gateway / direct access control ---
# API_KEY を設定すると /api/*（health/ready を除く）で x-api-key が必須になります。
# API_KEY=replace-me

# manager approval 用の canonical public URL（推奨）
# PUBLIC_APP_BASE_URL=https://your-app-host

# preview の GitHubCopilotAgent 品質レビューを opt-in するときだけ true
# ENABLE_GITHUB_COPILOT_REVIEW_AGENT=false
